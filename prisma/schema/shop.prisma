model Shop {
    id              String  @id @default(uuid())
    shopname        String
    shopLogo        String?
    shopCoverPhoto  String?
    shopdiscribtion String?
    sellerId        String  @unique
    seller          User    @relation(fields: [sellerId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("shops")
}
